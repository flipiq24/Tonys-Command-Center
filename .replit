modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-mail:1.0.0", "google-calendar:1.0.0", "agentmail:1.0.0", "google-drive:1.0.0", "google-sheet:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BUSINESS_MASTER_SHEET_ID = "1VXx88LTbuoTrnEssB50kBelGPX_nCVcclVrEAxJGEqE"
SUPABASE_DATABASE_URL = "postgresql://postgres.oqhizuvtgixmcnrwvvvj:command-center123.%40@aws-1-us-west-1.pooler.supabase.com:5432/postgres?sslmode=require"
